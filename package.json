{
  "name": "beastbots-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "npm -w @beastbots/api run dev",
    "dev:web": "npm -w @beastbots/web run dev",
    "dev:workers": "npm -w @beastbots/workers run dev",
    "dev:mcp": "npm -w @beastbots/mcp run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260310.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18",
    "wrangler": "^4.72.0",
    "turbo": "^2.0.4"
  },
  "dependencies": {
    "next": "16.1.6"
  },
  "overrides": {
    "next": "16.1.6"
  }
}
