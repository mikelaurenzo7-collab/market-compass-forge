JWT_SECRET=change-me
ENCRYPTION_KEY=change-me-encryption-key
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
API_BASE_URL=http://localhost:4000
WORKERS_BASE_URL=http://localhost:8787
