# Required
POSTGRES_USER=grapevine
POSTGRES_PASSWORD=grapevine
POSTGRES_DB=grapevine
SECRET_KEY=dev-secret-change-in-production

# Engine API
DATABASE_URL=postgresql://grapevine:grapevine@postgres:5432/grapevine_engine
CELERY_BROKER_URL=redis://redis:6379/1
CORS_ORIGINS=http://localhost:3000,http://web:3000

# Web API
ENGINE_API_URL=http://engine_api:8001

# Compute (optional - defaults to CPU)
COMPUTE_BACKEND=numpy
TORCH_DEVICE=cpu
# For GPU: COMPUTE_BACKEND=cupy, TORCH_DEVICE=cuda

# Exports (optional)
EXPORTS_DIR=/tmp/grapevine_exports

# Production
# CORS_ORIGINS=https://yourdomain.com
# SECRET_KEY=use-strong-random-key
