JWT_SECRET=change-me
ENCRYPTION_KEY=change-me-encryption-key
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
API_BASE_URL=http://localhost:4000
DATABASE_PATH=./beastbot.db
NODE_ENV=development

# ─── AI Providers ──────────────────────────────────────────────
OAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=

# ─── Payments & Email ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
EMAIL_FROM=BeastBots <noreply@beastbots.ai>

# ─── Webhook Signing Secrets ───────────────────────────────────
SHOPIFY_WEBHOOK_SECRET=
COINBASE_WEBHOOK_SECRET=
ALPACA_WEBHOOK_SECRET=

# ─── Trading Platforms ─────────────────────────────────────────
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
KALSHI_API_KEY=
COINBASE_API_KEY=
COINBASE_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=
ALPACA_API_KEY=
ALPACA_API_SECRET=

# ─── Social / X (Twitter) ─────────────────────────────────────
X_CLIENT_ID=
X_CLIENT_SECRET=
X_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ─── Social / Other ───────────────────────────────────────────
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ─── Bot Runtime ───────────────────────────────────────────────
DISABLE_AUTOPILOT=true
AUTOPILOT_INTERVAL_MS=300000
DISABLE_PREDICTION_BOT=false
PREDICTION_INTERVAL_MS=30000
DISABLE_CRYPTO_TRADING=false
CRYPTO_TRADING_INTERVAL_MS=15000
DISABLE_STOCK_TRADING=false
STOCK_TRADING_INTERVAL_MS=30000

# ─── LLM Defaults ─────────────────────────────────────────────
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=220
LLM_TIMEOUT_MS=8000
LLM_RETRIES=2
LLM_MAX_PROMPT_CHARS=4000
DISABLE_LLM=false
